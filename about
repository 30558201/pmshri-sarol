            { n: "Jitender Thakur", s: "Sports & Physical Ed.", c: "VI–X, XI–XII", v: true },
            { n: "Babita Kumari Dhiman", s: "IT-ITES", c: "XI–XII", v: true },
            { n: "Sonali Chawla", s: "Telecom", c: "IX–XII", v: true }
        ];

        const fGrid = document.getElementById('facultyGrid');
        const renderF = (data) => {
            fGrid.innerHTML = data.map(t => `
                <div class="glass-card faculty-card">
                    ${t.v ? '<div class="badge-voc">VOC</div>' : ''}
                    <div class="f-avatar"><i class="fas fa-user"></i></div>
                    <div class="f-name">${t.n}</div>
                    <div class="f-subj">${t.s}</div>
                    <div class="f-class">${t.c}</div>
                </div>
            `).join('');
        };
        renderF(faculty);

        // 3. Smart Search Filter
        document.getElementById('searchInput').addEventListener('input', (e) => {
            const v = e.target.value.toLowerCase();
            renderF(faculty.filter(t => t.n.toLowerCase().includes(v) || t.s.toLowerCase().includes(v)));
        });

        // 4. Scroll Logic (Progress, Back to Top, Nav Dots)
        const sBar = document.getElementById('scrollBar');
        const bTop = document.getElementById('backTop');
        const dots = document.querySelectorAll('.dot');
        const sections = document.querySelectorAll('section');

        window.addEventListener('scroll', () => {
            let winS = document.documentElement.scrollTop;
            let h = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            sBar.style.width = (winS / h) * 100 + "%";
            
            if (winS > 200) bTop.classList.add('show'); else bTop.classList.remove('show');

            let current = "";
            sections.forEach(sec => { if(winS >= (sec.offsetTop - 100)) current = sec.getAttribute('id'); });
            dots.forEach(d => {
                d.classList.remove('active');
                if(d.getAttribute('href').includes(current)) d.classList.add('active');
            });
        });
        bTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

        // 5. Intersection Observer (Fade Reveal & Counters)
        let countDone = false;
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                    if(entry.target.id === 'facts' && !countDone) {
                        countDone = true;
                        document.querySelectorAll('.count-up').forEach(el => {
                            let target = +el.getAttribute('data-val');
                            if(!target) return;
                            let c = 0, inc = target / 30;
                            let timer = setInterval(() => {
                                c += inc;
                                if(c >= target) { el.innerText = target; clearInterval(timer); } 
                                else el.innerText = Math.ceil(c);
                            }, 30);
                        });
                    }
                }
            });
        }, { threshold: 0.1 });
        document.querySelectorAll('.reveal, #facts').forEach(el => observer.observe(el));

        // 6. Typing Animation
        const txt = ["Building Futures.", "Empowering Rural Education.", "Inspiring Excellence."];
        let tI = 0, cI = 0, isDel = false, el = document.getElementById('typing');
        function type() {
            let cur = txt[tI];
            if(isDel) { el.innerText = cur.substring(0, cI-1); cI--; }
            else { el.innerText = cur.substring(0, cI+1); cI++; }
            
            if(!isDel && cI === cur.length) { isDel = true; setTimeout(type, 1500); }
            else if(isDel && cI === 0) { isDel = false; tI = (tI + 1) % txt.length; setTimeout(type, 500); }
            else setTimeout(type, isDel ? 30 : 60);
        }
        type();

        // 7. Floating Particles Generator
        const pCont = document.getElementById('particles');
        for(let i=0; i<8; i++){
            let p = document.createElement('div');
            p.className = 'particle';
            let size = Math.random() * 8 + 4;
            p.style.width = size + 'px'; p.style.height = size + 'px';
            p.style.left = Math.random() * 100 + 'vw';
            p.style.top = Math.random() * 100 + 'vh';
            p.style.animationDelay = Math.random() * 3 + 's';
            pCont.appendChild(p);
        }
    </script>
</body>
</html>
